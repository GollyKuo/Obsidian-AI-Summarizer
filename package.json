{
  "name": "obsidian-ai-summarizer",
  "version": "0.1.57-media-smoke-and-ffmpeg-location",
  "description": "將網頁與媒體內容整理成結構化的 Obsidian 筆記。",
  "main": "main.js",
  "scripts": {
    "version:sync": "node scripts/sync-version-from-dev-log.mjs",
    "predev": "npm run version:sync",
    "predev:vault": "npm run version:sync",
    "predev:vault:target": "npm run version:sync",
    "prebuild": "npm run version:sync",
    "prebuild:vault": "npm run version:sync",
    "prebuild:vault:target": "npm run version:sync",
    "dev": "node esbuild.config.mjs --watch",
    "dev:vault": "node esbuild.config.mjs --watch --vault \"D:\\程式開發\\Obsidian Test\"",
    "dev:vault:target": "node scripts/vault-sync.mjs --mode watch",
    "build": "node esbuild.config.mjs --production",
    "build:vault": "node esbuild.config.mjs --production --vault \"D:\\程式開發\\Obsidian Test\"",
    "build:vault:target": "node scripts/vault-sync.mjs --mode build",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "check:types": "npm run typecheck",
    "check:test": "npm run test",
    "check:build": "npm run build",
    "check:build:vault": "npm run build:vault",
    "test:regression:webpage": "vitest run --passWithNoTests tests/regression/webpage-flow.regression.test.ts",
    "gate:local": "npm run check:types && npm run check:test && npm run check:build",
    "gate:local:vault": "npm run check:types && npm run check:test && npm run check:build:vault",
    "gate:regression:desktop": "npm run test:regression:webpage",
    "smoke:webpage": "node scripts/smoke-checklist.mjs --capability webpage",
    "smoke:media-url": "node scripts/smoke-checklist.mjs --capability media_url",
    "smoke:local-media": "node scripts/smoke-checklist.mjs --capability local_media",
    "smoke:desktop": "node scripts/smoke-checklist.mjs --surface desktop",
    "smoke:mobile": "node scripts/smoke-checklist.mjs --surface mobile",
    "gate:release": "npm run gate:local && npm run gate:regression:desktop && npm run smoke:desktop && npm run smoke:mobile",
    "validate": "npm run gate:local"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "summarizer"
  ],
  "author": "GollyKuo <gollykuo@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.19",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "esbuild": "^0.25.3",
    "obsidian": "^1.8.10",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
